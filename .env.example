# Sombra runtime configuration
PORT=4000

# Public Solana RPC endpoint used for live explorer lookups.
# You can replace this with a private RPC URL for higher limits.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Set to false to disable live RPC explorer mode and use local fallback data.
SOLANA_LIVE_EXPLORER=true
# Optional Supabase persistence. Use the same shared Supabase project as your other hackathon apps.
# Run supabase/schema.sql manually before enabling these values.
SUPABASE_SERVER_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_AUDIT_TABLE=sombra_audit_events
SUPABASE_FEEDBACK_TABLE=sombra_feedback
